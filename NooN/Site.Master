<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="NooN.SiteMaster" %>

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%: Page.Title %> - Noon — متجر الكل</title>

    <link href="Content/shared.css" rel="stylesheet" />
    <link href="Content/master.css" rel="stylesheet" />
    <asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>

    <style>
        body { margin: 0; padding-top: 0; background-color: #f7f7f7; }
        .main-content-area { padding: 20px; min-height: 600px; }
        .btn-search-hidden {
            position: absolute; width: 0; height: 0;
            opacity: 0; overflow: hidden; border: none; padding: 0;
        }
        .nav-category-ddl {
            height: 38px; padding: 0 10px;
            border: 1px solid #ddd; border-radius: 8px;
            font-size: 14px; background: #fff;
            cursor: pointer; min-width: 140px; color: #333;
        }
        .nav-category-ddl:focus { outline: none; border-color: #f5a623; }
        /* Toast used by Scripts/noon-shop.js (AJAX cart/favorites) */
        #noonToast {
            position: fixed; bottom: 24px; right: 24px; z-index: 99999;
            max-width: 340px; padding: 12px 20px; border-radius: 10px;
            font-weight: 600; direction: rtl;
            box-shadow: 0 6px 24px rgba(0,0,0,.18);
            opacity: 0; visibility: hidden; transform: translateY(10px);
            transition: opacity .3s, transform .3s, visibility .3s;
            background: #eaffea; color: #27ae60; border: 1px solid #c3e6cb;
        }
        #noonToast.error { background: #ffeaea; color: #c0392b; border-color: #f5c6cb; }
        #noonToast.show { opacity: 1; visibility: visible; transform: translateY(0); }
    </style>
</head>

<body>
    <form id="form1" runat="server" defaultbutton="btnSearch">

        <%-- ✅ ScriptManager without any extra settings --%>
        <asp:ScriptManager ID="ScriptManager1" runat="server" />

        <nav class="navbar">

            <asp:HyperLink ID="lnkHomeLogo" runat="server"
                NavigateUrl="~/Default.aspx" CssClass="nav-logo">
                Noon<span>.</span>
            </asp:HyperLink>

            <%-- ══ Search — UpdatePanel Conditional ══ --%>
            <asp:UpdatePanel ID="upSearch" runat="server"
                UpdateMode="Conditional" ChildrenAsTriggers="false">
                <ContentTemplate>
                    <div class="nav-search">
                        <span class="nav-search-icon"
                            onclick="document.getElementById('<%= btnSearch.ClientID %>').click();"
                            style="cursor:pointer;">🔍</span>
                        <asp:TextBox ID="txtSearch" runat="server"
                            placeholder="searh to prouduct....."
                            CssClass="search-input" />
                        <asp:Button ID="btnSearch" runat="server"
                            CssClass="btn-search-hidden"
                            OnClick="btnSearch_Click"
                            Text="بحث" />
                    </div>
                </ContentTemplate>
                <Triggers>
                    <%-- ✅ Only the search updates this Panel --%>
                    <asp:AsyncPostBackTrigger ControlID="btnSearch"
                        EventName="Click" />
                </Triggers>
            </asp:UpdatePanel>

            <%-- ✅ Categories via JavaScript only — without any PostBack --%>
            <asp:DropDownList ID="ddlCategories" runat="server"
                CssClass="nav-category-ddl"
                onchange="navigateToCategory(this)" />

            <div class="nav-actions">
                <a href="Default.aspx" class="nav-btn">
                    🏠 <span class="label">الرئيسية</span>
                </a>
                <a href="Prouduct.aspx" class="nav-btn">
                    🛍️ <span class="label">المنتجات</span>
                </a>
                <asp:HyperLink ID="btnProfile" runat="server"
                    NavigateUrl="~/Userprofile.aspx" CssClass="nav-btn">
                    👤 <span class="label">حسابي</span>
                </asp:HyperLink>

                <%-- ✅ Cart — UpdatePanel Conditional only --%>
                <asp:UpdatePanel ID="upCart" runat="server"
                    UpdateMode="Conditional" ChildrenAsTriggers="false">
                    <ContentTemplate>
                        <a href="Cart.aspx" class="nav-btn cart-btn">
                            🛒 <span class="label">السلة</span>
                            <asp:Label ID="lblCartBadge" runat="server"
                                CssClass="cart-badge" />
                        </a>
                    </ContentTemplate>
                </asp:UpdatePanel>

            </div>
        </nav>

        <div class="main-content-area">
            <asp:ContentPlaceHolder ID="MainContent" runat="server">
            </asp:ContentPlaceHolder>
        </div>

        <footer style="text-align:center; padding:20px;
                       background:#fff; border-top:1px solid #ddd;">
            <p>&copy; <%: DateTime.Now.Year %> - Noon Application</p>
        </footer>

    </form>

    <script src="Scripts/noon-shop.js"></script>
    <script src="Scripts/master.js" defer></script>
    <script>
        function navigateToCategory(ddl) {
            var val = ddl.value;
            if (val && val !== "0")
                window.location.href = "Prouduct.aspx?category_id=" + val;
            else if (val === "0")
                window.location.href = "Prouduct.aspx";
        }
    </script>
</body>
</html>
